# ============================================================
# 存储配置
# ============================================================

# 存储驱动：sqlite（默认）或 postgres
# 未设置时自动检测：有 DATABASE_URL 用 postgres，否则用 sqlite
# STORAGE_DRIVER=sqlite

# PostgreSQL 连接（仅 STORAGE_DRIVER=postgres 时需要）
# DATABASE_URL=postgres://postgres:password@localhost:5432/careertrack

# SQLite 数据库路径（可选，默认 .careertrack/careertrack.db）
# SQLITE_DB_PATH=.careertrack/careertrack.db

# ============================================================
# 应用配置
# ============================================================

# JWT 签名密钥（必须修改！）
JWT_SECRET=change-me-in-production

# Gravatar 头像镜像（可选）
# NEXT_PUBLIC_GRAVATAR_BASE=https://gravatar.loli.net/avatar

# 公开站点地址（用于 SEO/OG/Sitemap）
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# GitHub OAuth（可选，用于 GitHub 登录/注册）
# ============================================================

# GitHub OAuth App 的 Client ID
# GITHUB_CLIENT_ID=

# GitHub OAuth App 的 Client Secret
# GITHUB_CLIENT_SECRET=

# GitHub OAuth 回调地址（需与 GitHub OAuth App 配置一致）
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback
